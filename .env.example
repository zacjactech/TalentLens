# PostgreSQL
POSTGRES_USER=talentlens_user
POSTGRES_PASSWORD=talentlens_password
POSTGRES_DB=talentlens_db

# MinIO (Local Object Storage)
MINIO_ROOT_USER=admin
MINIO_ROOT_PASSWORD=change_this_password

# Security
INTERNAL_API_KEY=your_internal_secret_key_here

# Redis
REDIS_URL=redis://redis:6379/0

# Gemini
GEMINI_API_KEY=

# Google Calendar
GOOGLE_CALENDAR_CREDENTIALS_JSON=

# Authentication
JWT_SECRET_KEY=change_this_to_a_secure_random_string_in_production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
